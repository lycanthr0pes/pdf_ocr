PDF_RENDER_DPI=220
INPUT_DIR=data/input
WORK_DIR=data/work
OUTPUT_DIR=data/output
ALLOW_MOCK_OCR=true

# owocr (Chrome Screen AI fixed)
# Install example: python -m pip install "owocr[screenai]"
OWOCR_EXECUTABLE=owocr
# Optional extra args passed after -r and -w. Leave blank unless your local setup needs them.
OWOCR_EXTRA_ARGS=
